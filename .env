# =============================================================================
# 智枢文档 · 环境变量（与 config.py / webapp.py 一致）
# 说明：未列出的项使用代码内默认值；dotenv 不覆盖已在进程中设置的环境变量。
# =============================================================================

# ----- 应用与上传 -----
DEBUG=false
DATA_DIR=./data
# INPUT_DIR、OUTPUT_DIR 未设置时分别为 DATA_DIR/input、DATA_DIR/output
MAX_FILE_SIZE=500MB
ALLOWED_TYPES=pdf,docx,png,jpg,jpeg,xlsx

# 前端显示的、同时可处理的任务，最大并发任务数
WORKER_MAX_PARALLEL_JOBS=8

# ----- MinerU HTTP（对接 mineru-api 与兼容路由；与官方 multipart 表单字段一致）-----
# MINERU_BASE_URL：MinerU 服务根地址，无尾斜杠。未设置时程序默认 http://192.168.2.60:8011
MINERU_BASE_URL=http://127.0.0.1:8011
# MINERU_API_KEY：可选。若网关要求鉴权，客户端会带 Authorization: Bearer <值>（多数自建 mineru-api 可不填）
# MINERU_API_KEY=

# MINERU_PARSE_MODE：async=先 POST /tasks 再轮询状态与结果；sync=单次 POST /file_parse 阻塞直到完成
MINERU_PARSE_MODE=async
# MINERU_TIMEOUT_SEC：单次 HTTP 请求超时（秒），含连接与读响应；大文件或慢模型宜增大
MINERU_TIMEOUT_SEC=300
# MINERU_POLL_INTERVAL_SEC：仅 async 模式有效，两次 GET /tasks/{id} 状态轮询之间的间隔（秒）
MINERU_POLL_INTERVAL_SEC=1.5
# MINERU_MAX_WAIT_SEC：仅 async 模式有效，从提交任务起等待终态（completed/failed）的最长总时间（秒）
MINERU_MAX_WAIT_SEC=36000
# MINERU_VERIFY_SSL：HTTPS 时是否校验 TLS 证书；http:// 时无影响
MINERU_VERIFY_SSL=true

# MINERU_BACKEND：解析后端，与 MinerU 表单 backend 一致。常见值：
#   pipeline           通用、多语、无幻觉依赖
#   vlm-auto-engine    本地算力高精度（中英为主）
#   vlm-http-client    远程 OpenAI 兼容 VLM（需 MINERU_SERVER_URL）
#   hybrid-auto-engine 本地混合高精度（多语，默认常用）
#   hybrid-http-client 远程混合（需 MINERU_SERVER_URL，仍有一点本地计算）
MINERU_BACKEND=hybrid-auto-engine
# MINERU_PARSE_METHOD：仅 pipeline/hybrid 有意义。auto=按文件类型自动；txt=文本抽取；ocr=整页 OCR
MINERU_PARSE_METHOD=auto
# MINERU_LANG_LIST：逗号分隔，对应多个表单字段 lang_list（如 ch,en）。影响 pipeline/hybrid 的 OCR/语言相关能力
MINERU_LANG_LIST=ch
# MINERU_FORMULA_ENABLE：是否启用公式解析（MinerU 表单 formula_enable）
MINERU_FORMULA_ENABLE=true
# MINERU_TABLE_ENABLE：是否启用表格解析（MinerU 表单 table_enable）
MINERU_TABLE_ENABLE=true
# MINERU_SERVER_URL：仅 *-http-client 类 backend 需要，填 OpenAI 兼容网关根 URL，如 http://127.0.0.1:30000/v1
MINERU_SERVER_URL=http://192.168.2.60:11434/v1

# MINERU_RETURN_MD：是否在结果中取 Markdown（true 时从 JSON results[*].md_content 写入任务输出 .md）
MINERU_RETURN_MD=true
# MINERU_RETURN_MIDDLE_JSON：是否在结果中包含中间 JSON（体积大，一般 false）
MINERU_RETURN_MIDDLE_JSON=false
# MINERU_RETURN_MODEL_OUTPUT：是否在结果中包含模型原始输出 JSON
MINERU_RETURN_MODEL_OUTPUT=false
# MINERU_RETURN_CONTENT_LIST：是否在结果中包含 content_list 类 JSON
MINERU_RETURN_CONTENT_LIST=false
# MINERU_RETURN_IMAGES：是否在结果中带出图片（JSON 内嵌 base64 或 ZIP 内文件；体积大）
MINERU_RETURN_IMAGES=false
# MINERU_RESPONSE_FORMAT_ZIP：true 时 GET …/result 为 ZIP 包，本应用会解压取 .md；false 时优先 JSON
MINERU_RESPONSE_FORMAT_ZIP=true
# MINERU_RETURN_ORIGINAL_FILE：ZIP 结果中是否附带处理后的原文件；仅当 RESPONSE_FORMAT_ZIP=true 时有效
MINERU_RETURN_ORIGINAL_FILE=false
# MINERU_START_PAGE_ID / MINERU_END_PAGE_ID：PDF 页范围，MinerU 约定从 0 起；大文档可缩小范围试跑
MINERU_START_PAGE_ID=0
MINERU_END_PAGE_ID=99999

# ----- 表格语义增强（MinerU 产出 .md 落盘后，调用 OpenAI-compatible 接口为表格写检索摘要；默认关闭）-----
# TABLE_SEMANTIC_ENABLE：true 时在 MINERU 转换成功后对输出 Markdown 中的表格（GFM 管道表 + HTML <table>）追加语义块
TABLE_SEMANTIC_ENABLE=true
# TABLE_SEMANTIC_BASE_URL：大模型网关根地址。可带或不带 /v1，程序会规范为 …/v1/chat/completions
TABLE_SEMANTIC_BASE_URL=http://192.168.2.60:11434/v1
# TABLE_SEMANTIC_API_KEY：可选。需要鉴权时填 Bearer Token；与 MINERU_API_KEY 无关
TABLE_SEMANTIC_API_KEY=sk-11
# TABLE_SEMANTIC_MODEL：chat/completions 的 model 名称，按你方网关要求填写
TABLE_SEMANTIC_MODEL=qwen3.5:35b-a3b
# TABLE_SEMANTIC_TIMEOUT_SEC：单次大模型请求超时（秒），至少 5
TABLE_SEMANTIC_TIMEOUT_SEC=600
# TABLE_SEMANTIC_MAX_CONCURRENCY：多表时并发请求数上限（仅限制连接数，非 token 上限）
TABLE_SEMANTIC_MAX_CONCURRENCY=4
# TABLE_SEMANTIC_CONTEXT_BEFORE_CHARS / TABLE_SEMANTIC_CONTEXT_AFTER_CHARS：
#   传给模型的「表格前」「表格后」上下文字符数。整行变量留空或不写 = 使用全文前缀/后缀（不设上限）。
#   若需截断可填非负整数，例如 4000。
TABLE_SEMANTIC_CONTEXT_BEFORE_CHARS=1000
TABLE_SEMANTIC_CONTEXT_AFTER_CHARS=1000
# TABLE_SEMANTIC_ON_ERROR：表格语义阶段失败时行为。skip=跳过增强、任务仍算成功；fail=抛出错误使任务失败
TABLE_SEMANTIC_ON_ERROR=skip
# TABLE_SEMANTIC_THINKING_ENABLE：chat/completions 请求体顶层 "thinking" 布尔（Ollama OpenAI 兼容；Qwen3.5 等）。true/false 均会按配置原样传入
TABLE_SEMANTIC_THINKING_ENABLE=false

# ----- 数据库（MySQL 示例；SQLite 时改 DB_TYPE 并配置 AUTH_DB_PATH）-----
DB_TYPE=mysql
DATABASE_URL=mysql+pymysql://docling:123456!@192.168.2.60:3306/docling_demo?charset=utf8mb4
# DB_TYPE=sqlite 时使用：
# AUTH_DB_PATH=./data/auth.db


# ----- OA 登录（OA_AUTH_ENABLED=true 时走远程登录；管理员兜底见 README）-----
OA_AUTH_ENABLED=true
OA_AUTH_LOGIN_URL=http://192.168.3.213:8000/prod-api/admin-api/system/auth/login
OA_AUTH_TENANT_ID=1
# 未设置时程序内默认四个空格；若需真正空串可写 OA_AUTH_TENANT_NAME=
OA_AUTH_TENANT_NAME=
# OA_AUTH_REMEMBER_ME=true
# OA_AUTH_VERIFY_SSL=false
# OA_AUTH_TIMEOUT_SEC=15
# OA_AUTH_ORIGIN=
# OA_AUTH_REFERER=
# OA_AUTH_USER_AGENT=
# OA_AUTH_COOKIE=
# OA_AUTH_TRUST_ENV=false


# ----- 会话与本地账号（非 OA 用户 / 管理员兜底）-----
SESSION_SECRET=replace_with_a_strong_secret
# ACCESS_TOKEN_SECRET=
ACCESS_TOKEN_TTL_SEC=86400
AUTH_ADMIN_USERNAME=admin
INITIAL_PASSWORD=123456!
# AUTH_USERS=user1,user2,user3

# ----- Web 日志（webapp 启动时读取；子进程 worker 另读 RUN_LOG_FILE）-----
LOG_DIR=./logs
LOG_ROTATE_MODE=time
LOG_RETENTION_DAYS=7
LOG_MAX_BYTES=52428800
LOG_BACKUP_COUNT=10
# RUN_LOG_FILE=
