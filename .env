# ========= 基础服务配置 =========
# 单文件最大上传体积（支持 B/KB/MB/GB）
MAX_FILE_SIZE=500MB
# 允许上传的扩展名（逗号分隔，不带点）
ALLOWED_TYPES=pdf,docx,pptx,html,png,jpg,jpeg,xlsx
# 数据根目录（会在其下使用 input/output）
DATA_DIR=./data
# 是否开启 FastAPI debug 模式
DEBUG=false
# 是否自动清理历史任务目录
AUTO_CLEANUP=false
# 自动清理阈值（小时）
CLEANUP_MAX_AGE_HOURS=240

# ========= 转换参数（对齐原 CLI 常用项） =========
# 是否启用 PDF 按页 VL 转写主流程
PDF_VL_PRIMARY=true
# PDF 渲染 DPI（常用 180）
PDF_VL_DPI=180
# 页级并发 worker 数（本地单卡 27B 建议 1，避免多请求排队/显存抖动）
PDF_VL_WORKERS=5
# DashScope / Qwen 模型名
LLM_MODEL=qwen3.5:35b-a3b
# 大模型 OpenAI 兼容 API 根地址（需与密钥地域一致；国际版示例见 README）
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

LLM_BASE_URL=http://127.0.0.1:11434/v1
# 每页可疑表格二次校对数量上限
PDF_VL_TABLE_SECOND_PASS_MAX_TABLES=5
# 每个文档最大处理页数（空表示不限制）
MAX_NUM_PAGES=
# LLM 单次返回 token 上限（本地 27B 不宜过大：越大生成越久、越易超时；PDF-VL 单页通常 4k~8k 足够）
LLM_MAX_TOKENS=8192
# LLM 采样温度
LLM_TEMPERATURE=0
# 是否开启 Qwen thinking（云端百炼建议 true；本地 Ollama+27B 若频繁超时/空 content，可改为 false 降延迟）
LLM_ENABLE_THINKING=true
# 是否生成表格信息转述
LLM_TABLE_CAPTION=true
# 表格信息转述最大字符数
LLM_TABLE_CAPTION_MAX_CHARS=2000
# 是否按图题裁切局部插图（对应 main.py: --pdf-caption-crop-figures / --no-pdf-caption-crop-figures）
PDF_CAPTION_CROP_FIGURES=false
# 是否对 Markdown 中图片做语义补充（写回引用图下方；与 main.py --llm-image-caption 一致，Web 默认 true）
LLM_IMAGE_CAPTION=false
# LLM_IMAGE_CAPTION_MAX_IMAGES=0
# 图片信息转述最大字符数
LLM_IMAGE_CAPTION_MAX_CHARS=2000
# LLM_IMAGE_CAPTION_CONTEXT_LINES=3


# 每页最多裁切插图数（对应 CLI: --pdf-caption-crop-max-per-page）
# PDF_CAPTION_CROP_MAX_PER_PAGE=4

# ---------- 大模型 HTTP 客户端（与百炼/OpenAI 兼容接口一致）----------
# 读取 API Key 的环境变量名
LLM_API_KEY_ENV=DASHSCOPE_API_KEY
# 请求失败重试次数、退避秒数（超时类失败重试会再卡一整段 LLM_TIMEOUT_SEC，建议 2）
LLM_MAX_RETRIES=3
LLM_RETRY_BACKOFF_SEC=2.0
# 单次请求超时（秒）：流式下含「等首包」时间；本地 27B+VLM 建议 900~1800
LLM_TIMEOUT_SEC=600
# 思考模式开启时，百炼请求体 max_reasoning_tokens（关闭思考时由程序置 0）；本地推理建议 2048~4096，勿顶格 8192
LLM_MAX_REASONING_TOKENS=4096
# assistant.content 为空时的最大重试次数（含兼容接口特殊处理）
LLM_EMPTY_CONTENT_MAX_ATTEMPTS=3
# 为 true 时：OpenAI 兼容 /chat/completions 使用流式响应，日志中实时打印模型正文片段（推理链为 DEBUG）
LLM_LOG_STREAM_RESPONSE=false
# 多模态消息里最多附带几张图（清洗/纠错）
LLM_CLEANUP_MAX_IMAGES=6
# 图片路径传给 VL 的方式：local_abs | url
# LLM_VL_IMAGE_MODE=local_abs

# ---------- Web：是否在 Docling 流程后启用 LLM 精修（需 enable_llm_refine 代码路径）----------
# LLM_ENABLE_REFINE=false

# ---------- 表格：按块纠错 / 题注 ----------
# LLM_TABLE_REFINE=false
# LLM_TABLE_CLEANUP_MAX_TABLES=10
# LLM_TABLE_CLEANUP_MAX_IMAGES_PER_TABLE=6
# LLM_TABLE_CONTEXT_LINES=2
# LLM_TABLE_CAPTION_MAX_TABLES=20
# LLM_TABLE_CAPTION_CONTEXT_LINES=3
# 表格题注补全的 max_tokens 由 LLM_TABLE_CAPTION_MAX_CHARS 与 LLM_MAX_TOKENS 推导，无需单独配置

# ---------- Docling 质量 rerun ----------
# LLM_ALLOW_RERUN=false
# LLM_RERUN_MAX_ATTEMPTS=1

# ---------- PDF-VL 其它 ----------
# 是否做可疑表格二次 LLM 校对
# PDF_VL_TABLE_SECOND_PASS=true

# ========= 第三方密钥 =========
# 百炼 DashScope API Key（必填）
DASHSCOPE_API_KEY=sk-11111111111111111111111111111111

# ========= 登录认证配置（SQLite + 会话） =========
# SQLite 用户库路径
AUTH_DB_PATH=./data/auth.db
# 会话签名密钥（生产环境务必改成随机长字符串）
SESSION_SECRET=replace_with_a_strong_secret
# 系统初始化时的统一初始密码（仅初始化新用户，实际入库为哈希）
INITIAL_PASSWORD=123456!
# 管理员用户名（管理员不通过 Web 操作，仅用于预留角色）
AUTH_ADMIN_USERNAME=admin
# 普通用户名单（逗号分隔）
AUTH_USERS=user1,user2,user3,user4,user5
