# =========================
# Docker CPU 运行配置模板
# =========================

# ---------- 基础 ----------
DEBUG=false
DATA_DIR=/app/data
MAX_FILE_SIZE=500MB
ALLOWED_TYPES=pdf,docx,png,jpg,jpeg,xlsx

# ---------- Web 任务并发 ----------
WORKER_MAX_PARALLEL_JOBS=3
PDF_VL_WORKERS=2
MAX_NUM_PAGES=

# ---------- PDF-VL / LLM ----------
PDF_VL_PRIMARY=true
PDF_VL_DPI=180
LLM_MODEL=qwen3.5:35b-a3b
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=6000
LLM_ENABLE_THINKING=false
LLM_TABLE_CAPTION=true
LLM_TABLE_CAPTION_MAX_TABLES=0
PDF_CAPTION_CROP_FIGURES=false
LLM_IMAGE_CAPTION=false

# LLM API Key 从哪个环境变量名读取
LLM_API_KEY_ENV=DASHSCOPE_API_KEY

# 选项 B：宿主机 Ollama（取消注释并注释掉上面的云端地址）
LLM_BASE_URL=http://192.168.2.60:11434/v1

# 填你的真实密钥（不要提交到 git）
DASHSCOPE_API_KEY=replace-with-real-key

# ---------- DB / 登录 ----------
DB_TYPE=mysql
# 容器内连接 compose 服务名 mysql（默认账号可按需修改）
DATABASE_URL=mysql+pymysql://docling:docling123@mysql:3306/docling_demo?charset=utf8mb4
# 使用 MySQL 时，AUTH_DB_PATH 不生效（仅 sqlite 生效）
# AUTH_DB_PATH=/app/data/auth.db
SESSION_SECRET=1234567890!234
ACCESS_TOKEN_SECRET=sk-1111
AUTH_ADMIN_USERNAME=admin
INITIAL_PASSWORD=123456!

# ---------- OA 登录（按需）----------
OA_AUTH_ENABLED=false
# OA_AUTH_LOGIN_URL=http://your-oa-host:8000/prod-api/admin-api/system/auth/login
# OA_AUTH_TENANT_ID=1
# OA_AUTH_TENANT_NAME=
