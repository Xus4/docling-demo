# 复制为 .env.docker 后由 docker compose 加载（勿提交含真实密钥的 .env.docker）
# 应用镜像内路径见 Dockerfile WORKDIR=/app

DEBUG=false
DATA_DIR=/app/data
INPUT_DIR=/app/data/input
OUTPUT_DIR=/app/data/output
LOG_DIR=/app/logs
LOG_ROTATE_MODE=time
LOG_RETENTION_DAYS=7

MAX_FILE_SIZE=500MB
ALLOWED_TYPES=pdf,docx,png,jpg,jpeg,xlsx

WORKER_MAX_PARALLEL_JOBS=2

# ---------- MinerU（容器须能访问 MINERU_BASE_URL；语义与根目录 .env 相同）----------
# MINERU_BASE_URL：内网 mineru-api 根地址；Docker 桥接网络需能路由到该 IP
MINERU_BASE_URL=http://192.168.2.60:8011
# MINERU_API_KEY：可选，Bearer 鉴权
# MINERU_PARSE_MODE：async | sync
MINERU_PARSE_MODE=async
MINERU_TIMEOUT_SEC=300
MINERU_POLL_INTERVAL_SEC=1.5
MINERU_MAX_WAIT_SEC=3600
MINERU_VERIFY_SSL=true
MINERU_BACKEND=hybrid-auto-engine
MINERU_PARSE_METHOD=auto
MINERU_LANG_LIST=ch
MINERU_FORMULA_ENABLE=true
MINERU_TABLE_ENABLE=true
# MINERU_SERVER_URL=
MINERU_RETURN_MD=true
MINERU_RETURN_MIDDLE_JSON=false
MINERU_RETURN_MODEL_OUTPUT=false
MINERU_RETURN_CONTENT_LIST=false
MINERU_RETURN_IMAGES=false
MINERU_RESPONSE_FORMAT_ZIP=false
MINERU_RETURN_ORIGINAL_FILE=false
MINERU_START_PAGE_ID=0
MINERU_END_PAGE_ID=99999

# ---------- DB（与 compose 中 mysql 服务一致）----------
DB_TYPE=mysql
DATABASE_URL=mysql+pymysql://docling:docling123@mysql:3306/docling_demo?charset=utf8mb4

SESSION_SECRET=change-me-in-docker
ACCESS_TOKEN_SECRET=
AUTH_ADMIN_USERNAME=admin
INITIAL_PASSWORD=ChangeMe123!

OA_AUTH_ENABLED=false
