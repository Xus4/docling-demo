# 复制为 .env 后按需修改（勿提交含真实密钥的 .env）
# 完整变量说明见仓库根目录 .env 注释分区或 README。

# OA_AUTH_ENABLED=false
# OA_AUTH_LOGIN_URL=

DEBUG=false
DATA_DIR=./data
MAX_FILE_SIZE=20MB
ALLOWED_TYPES=pdf,docx,png,jpg,jpeg,xlsx
WORKER_MAX_PARALLEL_JOBS=1

# ---------- MinerU（与 mineru-api 表单一致；详见根目录 .env 内同节长注释）----------
MINERU_BASE_URL=http://192.168.2.60:8011
# MINERU_PARSE_MODE=async
# MINERU_TIMEOUT_SEC=300
# MINERU_BACKEND=hybrid-auto-engine
# MINERU_PARSE_METHOD=auto
# MINERU_LANG_LIST=ch

DB_TYPE=sqlite
SESSION_SECRET=change-me
INITIAL_PASSWORD=ChangeMe123!

LOG_DIR=./logs
LOG_ROTATE_MODE=time
LOG_RETENTION_DAYS=7
